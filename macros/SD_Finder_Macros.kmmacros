						<false/>
						<key>MacroActionType</key>
						<string>ExecuteAppleScript</string>
						<key>Text</key>
						<string>tell application "Finder" to activate
delay 0.2
tell application "System Events"
    tell process "Finder"
        tell menu bar 1
            tell menu bar item "File"
                tell menu 1
                    tell menu item "Share"
                        tell menu 1
                            click menu item "AirDrop…"
                        end tell
                    end tell
                end tell
            end tell
        end tell
    end tell
end tell</string>
