						<key>MacroActionType</key>
						<string>ExecuteAppleScript</string>
						<key>Text</key>
						<string>tell application "Finder"
    set finderWindow to window 1
    set finderPath to POSIX path of (target of finderWindow as alias)
end tell
tell application "Terminal"
    activate
    do script "cd " &amp; quoted form of finderPath
end tell</string>
