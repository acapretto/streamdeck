						<string>ExecuteAppleScript</string>
						<key>Text</key>
						<string>set theText to "Think through this step by step before giving your final answer." &amp; return &amp; "" &amp; return &amp; "Context: [BACKGROUND]" &amp; return &amp; "Task: [WHAT YOU NEED]" &amp; return &amp; "Format: Show your reasoning briefly, then give a clear final answer." &amp; return &amp; "Constraints:" &amp; return &amp; "- Do not make assumptions — state them explicitly if you must make any" &amp; return &amp; "- Do not add unsolicited content beyond what I asked for" &amp; return &amp; "" &amp; return &amp; "[PASTE CONTENT OR QUESTION HERE]"
